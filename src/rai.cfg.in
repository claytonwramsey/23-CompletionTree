#CB/theta: .5
#CB/gamma: 1.
#CB/beta: 1.
#CB/epsilon: .01

#CB/method1: SCE_Thresholded
#CB/method1: SCE_RoundRobin

#CB/method2: SCE_Thresholded
#CB/method2: SCE_RoundRobin
#CB/method2: SCE_IterativeLimited
#CB/rr_sampleFreq: 3.
#CB/rr_computeFreq: 10.

Tree/maxDepth: 2 #flat bandit=2!!
Tree/hiddenTarget: 1
Tree/branching: -1.
Tree/badC: 10.
Tree/problem: 3   #{ none=0, Random, SingularLine, Bandits }

ELS/verbose: 0
ELS/w0: 1
ELS/wP: 1
ELS/c0: 1
ELS/cP: 1

solver: ELS
#solver: RoundRobin
#solver: TreePolicy


opt/verbose: 0
LGP/verbose: 0

LGP/level_wP: 2.
LGP/skeleton_wP: 2.
LGP/waypoint_wP: 2.

LGP/level_cP: 1.

LGP/evalLimit: 120

# @REPO_ROOT@ is substituted with this checkout's absolute path by
# ../generate-rai-cfg.sh (run automatically by `make` in this directory, or
# run it directly after moving/re-cloning the checkout). Must be absolute:
# rai's Graph config parser mis-parses list entries starting with `../`
# (silently fails to populate `problems`, then HALTs claiming the parameter
# was never set at all) so plain relative paths don't work here.
problem: @REPO_ROOT@/lgp-benchmarks/puzzles/2blocks.lgp

problems: [
@REPO_ROOT@/lgp-benchmarks/puzzles/2blocks.lgp
@REPO_ROOT@/lgp-benchmarks/puzzles/around2.lgp
@REPO_ROOT@/lgp-benchmarks/puzzles/around.lgp
@REPO_ROOT@/lgp-benchmarks/puzzles/cross-box.lgp
@REPO_ROOT@/lgp-benchmarks/puzzles/quim.lgp
@REPO_ROOT@/lgp-benchmarks/puzzles/sofa.lgp
@REPO_ROOT@/lgp-benchmarks/robot-pnp/move_table_bend.lgp
]
# pr2-onTray.lgp excluded: its .g file hardcodes PR2 mesh paths from an old
# rai-robotModels layout (ply files under pr2/meshes/base_v0/) that no longer
# exists in the current rai-robotModels repo (meshes are now .h5). Not worth
# pinning a historical rai-robotModels commit just for this one file.


